<mxfile host="app.diagrams.net">
  <diagram name="ProjectLens-API" id="projectlens-api">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1950" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="n1" value="&lt;b&gt;ProjectLens API 설계&lt;/b&gt; — 라우터 5개 + health · 인증색: &lt;font color=&#x27;#2d6a2d&#x27;&gt;■공개&lt;/font&gt; &lt;font color=&#x27;#2a5d8f&#x27;&gt;■옵션&lt;/font&gt; &lt;font color=&#x27;#b56a00&#x27;&gt;■필수&lt;/font&gt; · 응답은 camelCase alias" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=none;fontSize=15;align=left;" vertex="1" parent="1"><mxGeometry x="40" y="10" width="1840" height="40" as="geometry"/></mxCell>
        <mxCell id="n2" value="&lt;b&gt;auth  (routers/auth.py)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=center;spacing=6;fontSize=12;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1"><mxGeometry x="40" y="70" width="360" height="228" as="geometry"/></mxCell>
        <mxCell id="n3" value="&lt;b&gt;POST /auth/signup&lt;/b&gt;  &lt;font color=&#x27;#555&#x27;&gt;[공개]&lt;/font&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;UserCreate → UserOut (201)&lt;br/&gt;username/email 중복검사 + bcrypt 해싱&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=6;fontSize=11;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="52" y="110" width="336" height="78" as="geometry"/></mxCell>
        <mxCell id="n4" value="&lt;b&gt;POST /auth/login&lt;/b&gt;  &lt;font color=&#x27;#555&#x27;&gt;[공개 · 5/min]&lt;/font&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;OAuth2PasswordRequestForm → Token (JWT)&lt;br/&gt;SlowAPI rate limit&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=6;fontSize=11;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1"><mxGeometry x="52" y="200" width="336" height="78" as="geometry"/></mxCell>
        <mxCell id="n5" value="&lt;b&gt;posts  (routers/posts.py)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=center;spacing=6;fontSize=12;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1"><mxGeometry x="416" y="70" width="360" height="318" as="geometry"/></mxCell>
        <mxCell id="n6" value="&lt;b&gt;GET /posts&lt;/b&gt;  &lt;font color=&#x27;#555&#x27;&gt;[옵션]&lt;/font&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;q·tag·postType·cursor → {items, nextCursor}&lt;br/&gt;커서 페이징, repo에서 검색/정렬&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=6;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="428" y="110" width="336" height="78" as="geometry"/></mxCell>
        <mxCell id="n7" value="&lt;b&gt;GET /posts/{id}&lt;/b&gt;  &lt;font color=&#x27;#555&#x27;&gt;[옵션]&lt;/font&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;→ PostOut (404 if none)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=6;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="428" y="200" width="336" height="78" as="geometry"/></mxCell>
        <mxCell id="n8" value="&lt;b&gt;POST /posts&lt;/b&gt;  &lt;font color=&#x27;#555&#x27;&gt;[필수]&lt;/font&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;PostCreate → PostOut (201)&lt;br/&gt;service.create: 태그검증 + RAG 인덱싱&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=6;fontSize=11;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="428" y="290" width="336" height="78" as="geometry"/></mxCell>
        <mxCell id="n9" value="&lt;b&gt;comments  (routers/comments.py)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=center;spacing=6;fontSize=12;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1"><mxGeometry x="792" y="70" width="360" height="318" as="geometry"/></mxCell>
        <mxCell id="n10" value="&lt;b&gt;GET /posts/{id}/comments&lt;/b&gt;  &lt;font color=&#x27;#555&#x27;&gt;[옵션]&lt;/font&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;→ CommentOut[] (myLike 포함)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=6;fontSize=11;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1"><mxGeometry x="804" y="110" width="336" height="78" as="geometry"/></mxCell>
        <mxCell id="n11" value="&lt;b&gt;POST /posts/{id}/comments&lt;/b&gt;  &lt;font color=&#x27;#555&#x27;&gt;[필수]&lt;/font&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;CommentCreate → CommentOut (201)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=6;fontSize=11;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="804" y="200" width="336" height="78" as="geometry"/></mxCell>
        <mxCell id="n12" value="&lt;b&gt;POST /comments/{id}/like&lt;/b&gt;  &lt;font color=&#x27;#555&#x27;&gt;[필수]&lt;/font&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;→ CommentLikeOut {likeCount, myLike}&lt;br/&gt;votes 테이블 toggle&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=6;fontSize=11;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="804" y="290" width="336" height="78" as="geometry"/></mxCell>
        <mxCell id="n13" value="&lt;b&gt;votes  (routers/votes.py)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=center;spacing=6;fontSize=12;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1"><mxGeometry x="1168" y="70" width="360" height="138" as="geometry"/></mxCell>
        <mxCell id="n14" value="&lt;b&gt;POST /posts/{id}/vote&lt;/b&gt;  &lt;font color=&#x27;#555&#x27;&gt;[필수]&lt;/font&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;VoteIn{value: 1|-1} → VoteOut&lt;br/&gt;{score, myVote} · UNIQUE 제약&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=6;fontSize=11;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="1"><mxGeometry x="1180" y="110" width="336" height="78" as="geometry"/></mxCell>
        <mxCell id="n15" value="&lt;b&gt;analysis  (routers/analysis.py)&lt;br/&gt;prefix /posts/{id}/analysis&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;align=center;spacing=6;fontSize=12;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="1"><mxGeometry x="1544" y="70" width="360" height="408" as="geometry"/></mxCell>
        <mxCell id="n16" value="&lt;b&gt;POST (동기)&lt;/b&gt;  &lt;font color=&#x27;#555&#x27;&gt;[AI 실행]&lt;/font&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;→ AnalysisRunOut&lt;br/&gt;run_analysis_for_post (블로킹)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=6;fontSize=11;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="1556" y="110" width="336" height="78" as="geometry"/></mxCell>
        <mxCell id="n17" value="&lt;b&gt;POST /jobs&lt;/b&gt;  &lt;font color=&#x27;#555&#x27;&gt;[AI 비동기]&lt;/font&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;→ AnalysisJobOut (202)&lt;br/&gt;BackgroundTasks&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=6;fontSize=11;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="1556" y="200" width="336" height="78" as="geometry"/></mxCell>
        <mxCell id="n18" value="&lt;b&gt;GET /status&lt;/b&gt;  &lt;font color=&#x27;#555&#x27;&gt;[AI 폴링]&lt;/font&gt;&lt;br/&gt;&lt;font style=&#x27;font-size:10px&#x27;&gt;→ AnalysisJobOut&lt;br/&gt;post.analysis_status&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=6;fontSize=11;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1"><mxGeometry x="1556" y="290" width="336" height="78" as="geometry"/></mxCell>
